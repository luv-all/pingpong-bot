<?xml version="1.0"?>
<!-- competition_arm 프리셋에 대응하는 3DOF 예시 URDF (sim 테스트·뷰어용) -->
<robot name="pingpong_competition_arm">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <material name="base"><color rgba="0.2 0.25 0.55 1"/></material>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0.175 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.35"/></geometry>
      <material name="blue"><color rgba="0.25 0.45 0.85 1"/></material>
    </visual>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0 0.15 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
      <material name="blue2"><color rgba="0.25 0.45 0.85 1"/></material>
    </visual>
  </link>

  <link name="racket_link">
    <visual>
      <origin xyz="0.075 0 0" rpy="0 0 0"/>
      <geometry><box size="0.16 0.18 0.012"/></geometry>
      <material name="red"><color rgba="0.85 0.15 0.12 1"/></material>
    </visual>
  </link>

  <joint name="joint_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="-1.35 0.76 -1.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="10" velocity="2.5"/>
  </joint>

  <joint name="joint_shoulder" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0.35 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="1.4" effort="10" velocity="2.5"/>
  </joint>

  <joint name="joint_elbow" type="revolute">
    <parent link="link2"/>
    <child link="racket_link"/>
    <origin xyz="0 0.30 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="0.5" effort="10" velocity="2.5"/>
  </joint>
</robot>
